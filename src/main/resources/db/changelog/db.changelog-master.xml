<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-employees-table" author="gaurav">
        <createTable tableName="employees">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="age" type="int"/>
            </createTable>
    </changeSet>

    <changeSet id="002-insert-into-employees" author="gaurav">
        <insert tableName="employees">
            <column name="name" value="John Doe"/>
            <column name="age" valueNumeric="30"/>
        </insert>
        <insert tableName="employees">
            <column name="name" value="Jane Smith"/>
            <column name="age" valueNumeric="25"/>
        </insert>
        
    </changeSet>
    <changeSet id="insert-more-into-employees" author="gaurav">
        <insert tableName="employees">
            <column name="name" value="Alice Johnson"/>
            <column name="age" valueNumeric="28"/>
        </insert>
        <insert tableName="employees">
            <column name="name" value="Bob Williams"/>
            <column name="age" valueNumeric="35"/>
        </insert>
    </changeSet>

</databaseChangeLog>